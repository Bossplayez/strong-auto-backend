# ─── Runtime ───────────────────────────────────────────────
NODE_ENV="development"
PORT=3001

# ─── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/strong_auto"

# ─── JWT ────────────────────────────────────────────────────
JWT_ACCESS_SECRET="your-access-secret"
JWT_REFRESH_SECRET="your-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Frontend URL ───────────────────────────────────────────
FRONTEND_URL="https://strong-auto-frontend-zeta.vercel.app"

# ─── External APIs ──────────────────────────────────────────
RAPIDAPI_KEY=""

# ─── Sentry ─────────────────────────────────────────────────
SENTRY_DSN=""

# ─── Email (Resend) ─────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@strongauto.com.ua"

# ─── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""
TELEGRAM_MANAGER_CHAT_ID=""

# ─── Cloudflare R2 (File Storage) ───────────────────────────
# Leave empty to fall back to local storage (files won't persist across deploys)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="strong-auto-uploads"
# Public URL prefix for R2 objects (e.g. custom domain or r2.dev subdomain)
R2_PUBLIC_URL=""

# ─── Local Storage (fallback when R2 is not configured) ────
LOCAL_STORAGE_DIR="uploads"
